@{
}
@model List<Category>

<h2>Danh sách danh mục</h2>
<a asp-action="Create" class="btn btn-success">Thêm mới</a>

<table class="table mt-3">
    <thead>
        <tr>
            <th>Tên danh mục</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@c.Id">Sửa</a> |
                    <a asp-action="Delete" asp-route-id="@c.Id">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>

