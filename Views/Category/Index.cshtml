@model WEBDULICH.Models.PagedResult<WEBDULICH.Models.Category>
@{
    ViewData["Title"] = "Danh sách danh mục";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🏷️ Danh sách danh mục</h2>
        <a asp-action="Create" class="btn btn-success">➕ Thêm mới</a>
    </div>

    <!-- Search -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <input type="text" name="keyword" class="form-control" placeholder="Tìm theo tên..."
                           value="@Model.Keyword" />
                </div>
                <div class="col-md-3">
                    <select name="sortBy" class="form-select">
                        <option value="">-- Sắp xếp --</option>
                        <option value="name" selected="@(Model.SortBy == "name")">Tên</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="sortDir" class="form-select">
                        <option value="asc" selected="@(Model.SortDir == "asc")">Tăng dần</option>
                        <option value="desc" selected="@(Model.SortDir == "desc")">Giảm dần</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">🔍</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <p class="text-muted">Tìm thấy <strong>@Model.TotalCount</strong> danh mục</p>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Tên danh mục</th>
                        <th>Số điểm đến</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Items)
                    {
                        <tr>
                            <td>@c.Id</td>
                            <td><strong>@c.Name</strong></td>
                            <td>@(c.Destinations?.Count ?? 0)</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">✏️ Sửa</a>
                                <a asp-action="Delete" asp-route-id="@c.Id" class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Xóa danh mục này?')">🗑️ Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index"
                       asp-route-keyword="@Model.Keyword" asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir"
                       asp-route-page="@(Model.Page - 1)"><i class="bi bi-chevron-left"></i></a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-keyword="@Model.Keyword" asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir"
                           asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index"
                       asp-route-keyword="@Model.Keyword" asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir"
                       asp-route-page="@(Model.Page + 1)"><i class="bi bi-chevron-right"></i></a>
                </li>
            </ul>
        </nav>
    }
</div>
