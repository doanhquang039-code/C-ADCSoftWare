@using WEBDULICH.Models
@model List<Orders>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}
@{
    var billMessage = Context.Session.GetString("TransferSuccess");
    var confirmedEmail = Context.Session.GetString("ConfirmedEmail");
    var confirmedDate = Context.Session.GetString("ConfirmedDate");
}


<h2 class="text-center mb-4">🧾 Danh sách đơn hàng của bạn</h2>
@if (!string.IsNullOrEmpty(billMessage))
{
    <div class="alert alert-success text-center">
        @billMessage<br />
        📧 Email xác nhận: <strong>@confirmedEmail</strong><br />
        🗓️ Ngày đi: <strong>@confirmedDate</strong>
    </div>
}


@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        Bạn chưa đặt tour hoặc khách sạn nào.
    </div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead class="table-light text-center">
            <tr>
                <th>#</th>
                <th>Loại</th>
                <th>Tên Tour / Hotel</th>
                <th>Số lượng người đi</th>
                <th>Tổng tiền</th>
                <th>Ngày đặt</th>
                <th>Thanh toán</th>
                <th>Trạng thái</th>
                <th>Email nhận tin nhắn</th>
                <th>Thao tác</th>
                <th>
                    <a asp-controller="Orders" asp-action="PaidOrders" class="btn btn-success">Xem đơn đã thanh toán</a>
                </th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var order = Model[i];
                <tr>
                    <td class="text-center">@(i + 1)</td>

                    <td class="text-center">
                        @if (order.Tour != null)
                        {
                            <span class="badge bg-info text-dark">Tour</span>
                        }
                        else if (order.Hotel != null)
                        {
                            <span class="badge bg-success">Hotel</span>
                        }
                    </td>

                    <td>
                        @if (order.Tour != null)
                        {
                            <strong>@order.Tour.Name</strong>
                        }
                        else if (order.Hotel != null)
                        {
                            <strong>@order.Hotel.Name</strong>
                            @if (order.Hotel.Tour != null)
                            {
                                <div class="text-muted fst-italic small">
                                    (Thuộc tour: @order.Hotel.Tour.Name)
                                </div>
                            }
                        }
                    </td>

                    <td class="text-center">@order.Quantity</td>
                    <td>@order.TotalPrice.ToString("N0") $</td>
                    <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                    <td>@order.PaymentMethod</td>
                    <td>
                        @if (order.Status == "Đã thanh toán")
                        {
                            <span class="badge bg-success">Đã thanh toán</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">@order.Status</span>
                        }
                    </td>
                    <td>
                        @order.ConfirmedEmail
                    </td>
                    <td class="text-center">
                        @if (order.Status == "Chưa thanh toán" && order.PaymentMethod == "Chuyển khoản")
                        {
                            <a asp-action="Transfer" asp-route-id="@order.Id" class="btn btn-outline-primary btn-sm">
                                💳 Chuyển khoản
                            </a>
                        }
                    </td>

                </tr>
            }
        </tbody>
    </table>
}