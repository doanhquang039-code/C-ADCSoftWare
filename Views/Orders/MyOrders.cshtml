@using WEBDULICH.Models
@model WEBDULICH.Models.PagedResult<Orders>
@{
    ViewData["Title"] = "Đơn hàng";
    var billMessage = Context.Session.GetString("TransferSuccess");
    var confirmedEmail = Context.Session.GetString("ConfirmedEmail");
    var confirmedDate = Context.Session.GetString("ConfirmedDate");
    var isAdmin = ViewBag.IsAdmin ?? false;
}

<div class="container mt-4">
    <h2 class="text-center mb-4">🧾 @(isAdmin ? "Tất cả đơn hàng" : "Đơn hàng của bạn")</h2>

    @if (!string.IsNullOrEmpty(billMessage))
    {
        <div class="alert alert-success text-center">
            @billMessage<br />
            📧 Email xác nhận: <strong>@confirmedEmail</strong><br />
            🗓️ Ngày đi: <strong>@confirmedDate</strong>
        </div>
    }

    <!-- Search & Filter -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="MyOrders" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <input type="text" name="keyword" class="form-control" placeholder="Tìm theo tên tour/hotel, email..."
                           value="@Model.Keyword" />
                </div>
                <div class="col-md-2">
                    <select name="status" class="form-select">
                        <option value="">-- Trạng thái --</option>
                        <option value="Chưa thanh toán" selected="@(Model.Filters.GetValueOrDefault("status") == "Chưa thanh toán")">Chưa thanh toán</option>
                        <option value="Đã thanh toán" selected="@(Model.Filters.GetValueOrDefault("status") == "Đã thanh toán")">Đã thanh toán</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="sortBy" class="form-select">
                        <option value="">-- Sắp xếp --</option>
                        <option value="date" selected="@(Model.SortBy == "date")">Ngày đặt</option>
                        <option value="price" selected="@(Model.SortBy == "price")">Tổng tiền</option>
                        <option value="status" selected="@(Model.SortBy == "status")">Trạng thái</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <select name="sortDir" class="form-select">
                        <option value="desc" selected="@(Model.SortDir == "desc")">↓</option>
                        <option value="asc" selected="@(Model.SortDir == "asc")">↑</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">🔍 Tìm kiếm</button>
                    <a asp-action="MyOrders" class="btn btn-outline-secondary">Reset</a>
                    <a asp-action="PaidOrders" class="btn btn-success">✅ Đã TT</a>
                </div>
            </form>
        </div>
    </div>

    <p class="text-muted">Tìm thấy <strong>@Model.TotalCount</strong> đơn hàng</p>

    @if (!Model.Items.Any())
    {
        <div class="alert alert-info text-center">
            Bạn chưa đặt tour hoặc khách sạn nào.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark text-center">
                            <tr>
                                <th>#</th>
                                @if ((bool)isAdmin)
                                {
                                    <th>Khách hàng</th>
                                }
                                <th>Loại</th>
                                <th>Tên Tour / Hotel</th>
                                <th>Số lượng</th>
                                <th>Tổng tiền</th>
                                <th>Ngày đặt</th>
                                <th>Thanh toán</th>
                                <th>Trạng thái</th>
                                <th>Email</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Items.Count; i++)
                            {
                                var order = Model.Items[i];
                                <tr>
                                    <td class="text-center">@((Model.Page - 1) * Model.PageSize + i + 1)</td>
                                    @if ((bool)isAdmin)
                                    {
                                        <td>@order.User?.Name</td>
                                    }
                                    <td class="text-center">
                                        @if (order.Tour != null)
                                        {
                                            <span class="badge bg-info text-dark">Tour</span>
                                        }
                                        else if (order.Hotel != null)
                                        {
                                            <span class="badge bg-success">Hotel</span>
                                        }
                                    </td>
                                    <td>
                                        @if (order.Tour != null)
                                        {
                                            <strong>@order.Tour.Name</strong>
                                        }
                                        else if (order.Hotel != null)
                                        {
                                            <strong>@order.Hotel.Name</strong>
                                        }
                                    </td>
                                    <td class="text-center">@order.Quantity</td>
                                    <td>@order.TotalPrice.ToString("N0") $</td>
                                    <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                    <td>@order.PaymentMethod</td>
                                    <td>
                                        @if (order.Status == "Đã thanh toán")
                                        {
                                            <span class="badge bg-success">Đã thanh toán</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">@order.Status</span>
                                        }
                                    </td>
                                    <td>@order.ConfirmedEmail</td>
                                    <td class="text-center">
                                        @if (order.Status == "Chưa thanh toán" && order.PaymentMethod == "Chuyển khoản")
                                        {
                                            <a asp-action="Transfer" asp-route-id="@order.Id" class="btn btn-outline-primary btn-sm">
                                                💳 Chuyển khoản
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link" asp-action="MyOrders"
                           asp-route-keyword="@Model.Keyword" asp-route-status="@Model.Filters.GetValueOrDefault("status")"
                           asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir"
                           asp-route-page="@(Model.Page - 1)"><i class="bi bi-chevron-left"></i></a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="MyOrders"
                               asp-route-keyword="@Model.Keyword" asp-route-status="@Model.Filters.GetValueOrDefault("status")"
                               asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir"
                               asp-route-page="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link" asp-action="MyOrders"
                           asp-route-keyword="@Model.Keyword" asp-route-status="@Model.Filters.GetValueOrDefault("status")"
                           asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir"
                           asp-route-page="@(Model.Page + 1)"><i class="bi bi-chevron-right"></i></a>
                    </li>
                </ul>
                <p class="text-center text-muted small">Trang @Model.Page / @Model.TotalPages</p>
            </nav>
        }
    }
</div>