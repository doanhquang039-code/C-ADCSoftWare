@model WEBDULICH.Models.PagedResult<WEBDULICH.Models.Hotel>

<h2 class="text-center mb-4 text-primary">🏨 Danh sách Khách sạn</h2>
<div class="text-end mb-4">
    <a asp-action="Create" class="btn btn-success">
        ➕ Thêm khách sạn mới
    </a>
</div>

<div class="row">
    <!-- Cột bộ lọc bên trái -->
    <div class="col-lg-3 mb-4">
        <div class="filter-box">
            <h5><i class="bi bi-funnel"></i> Tìm kiếm & Lọc</h5>
            <form method="get" asp-action="Index">
                <input class="form-control" name="keyword" placeholder="Tên hotel..."
                       value="@Model.Keyword" />
                <input class="form-control" name="address" placeholder="Địa chỉ..."
                       value="@Model.Filters.GetValueOrDefault("address")" />
                <input class="form-control" name="minPrice" placeholder="Giá thấp nhất" type="number" min="0"
                       value="@Model.Filters.GetValueOrDefault("minPrice")" />
                <input class="form-control" name="maxPrice" placeholder="Giá cao nhất" type="number" min="0"
                       value="@Model.Filters.GetValueOrDefault("maxPrice")" />
                <input class="form-control" name="rating" placeholder="Số sao" type="number" min="1" max="5"
                       value="@Model.Filters.GetValueOrDefault("rating")" />

                <hr />
                <label class="form-label fw-bold"><i class="bi bi-sort-alpha-down"></i> Sắp xếp</label>
                <select name="sortBy" class="form-select">
                    <option value="">-- Mặc định --</option>
                    <option value="name" selected="@(Model.SortBy == "name")">Tên</option>
                    <option value="price" selected="@(Model.SortBy == "price")">Giá</option>
                    <option value="rating" selected="@(Model.SortBy == "rating")">Số sao</option>
                    <option value="quantity" selected="@(Model.SortBy == "quantity")">Số phòng</option>
                </select>
                <select name="sortDir" class="form-select">
                    <option value="asc" selected="@(Model.SortDir == "asc")">Tăng dần</option>
                    <option value="desc" selected="@(Model.SortDir == "desc")">Giảm dần</option>
                </select>

                <button type="submit" class="btn btn-primary w-100 mb-2">🔍 Tìm kiếm</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Xóa lọc</a>
            </form>
        </div>
    </div>

    <!-- Cột danh sách hotel bên phải -->
    <div class="col-lg-9">
        <p class="text-muted mb-3">Tìm thấy <strong>@Model.TotalCount</strong> khách sạn</p>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var h in Model.Items)
            {
                <div class="col">
                    <div class="card hotel-card h-100 shadow-sm">
                        <img src="~/ImageHotel/@h.Image" class="card-img-top hotel-image" />

                        <div class="card-body">
                            <h5 class="card-title text-primary fw-bold">Hotel: @h.Name</h5>
                            <p class="card-text text-muted">@h.Address</p>

                            <ul class="list-unstyled hotel-info">
                                <li><i class="bi bi-cash-coin"></i> <strong>Giá:</strong> @h.Price $ / 1đêm</li>
                                <li><i class="bi bi-star-fill text-warning"></i> <strong>Số sao:</strong> @h.Rating</li>
                                <li><i class="bi bi-house-door"></i> <strong>Phòng trống:</strong> @h.Quantity Phòng</li>
                                <li><i class="bi bi-geo-alt"></i> <strong>Tour:</strong> @h.Tour?.Name</li>
                            </ul>
                        </div>
                        <a asp-controller="Orders" asp-action="FormHotel" asp-route-hotelId="@h.Id" class="btn btn-sm btn-primary">Đặt ngay</a>

                        <div class="card-footer bg-transparent border-0 d-flex justify-content-between">
                            <a class="btn btn-sm btn-outline-primary rounded-pill" asp-action="Edit" asp-route-id="@h.Id">
                                ✏️ Sửa
                            </a>
                            <a class="btn btn-sm btn-outline-danger rounded-pill" asp-action="Delete" asp-route-id="@h.Id"
                               onclick="return confirm('Bạn có chắc muốn xóa khách sạn này?')">
                                🗑️ Xóa
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link" asp-action="Index"
                           asp-route-keyword="@Model.Keyword" asp-route-address="@Model.Filters.GetValueOrDefault("address")"
                           asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir"
                           asp-route-page="@(Model.Page - 1)"><i class="bi bi-chevron-left"></i></a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-keyword="@Model.Keyword" asp-route-address="@Model.Filters.GetValueOrDefault("address")"
                               asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir"
                               asp-route-page="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link" asp-action="Index"
                           asp-route-keyword="@Model.Keyword" asp-route-address="@Model.Filters.GetValueOrDefault("address")"
                           asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir"
                           asp-route-page="@(Model.Page + 1)"><i class="bi bi-chevron-right"></i></a>
                    </li>
                </ul>
                <p class="text-center text-muted small">Trang @Model.Page / @Model.TotalPages</p>
            </nav>
        }
    </div>
</div>

<style>
    .filter-box { background: #fff; border-radius: 16px; padding: 20px; box-shadow: 0 6px 20px rgba(0,0,0,0.08); margin-bottom: 30px; }
    .filter-box h5 { font-size: 18px; color: #007bff; font-weight: bold; display: flex; align-items: center; gap: 8px; margin-bottom: 15px; }
    .filter-box .form-control, .filter-box .form-select { border-radius: 12px; height: 42px; font-size: 15px; margin-bottom: 10px; }
    .filter-box .btn { border-radius: 25px; font-weight: 600; }
    body { background: linear-gradient(to left, #fffde7, #e0f2f1); font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    .hotel-card { border-radius: 16px; overflow: hidden; transition: all 0.3s ease; border: 1px solid #ddd; }
    .hotel-card:hover { transform: translateY(-6px); box-shadow: 0 10px 25px rgba(0,0,0,0.12); }
    .hotel-image { height: 200px; object-fit: cover; transition: transform 0.3s ease; }
    .hotel-card:hover .hotel-image { transform: scale(1.05); }
    .hotel-info li { font-size: 0.9rem; margin-bottom: 6px; color: #333; }
    .hotel-info i { color: #ff6f00; margin-right: 6px; }
</style>
