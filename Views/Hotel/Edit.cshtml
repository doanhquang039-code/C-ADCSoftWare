@{
}
@model WEBDULICH.Models.Hotel

@{
    ViewBag.Title = "Sửa Khách Sạn";
}

<h2 class="text-center text-primary mb-4">🛎️ Sửa khách sạn mới</h2>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card p-4 shadow-sm border-0 rounded-4 bg-light">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Tên khách sạn</label>
                    <input asp-for="Name" class="form-control rounded-3" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label fw-bold">Địa chỉ</label>
                    <input asp-for="Address" class="form-control rounded-3" />
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label fw-bold">Giá</label>
                    <input asp-for="Price" class="form-control rounded-3" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Rating" class="form-label fw-bold">Đánh giá (sao)</label>
                    <input asp-for="Rating" class="form-control rounded-3" />
                    <span asp-validation-for="Rating" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Quantity" class="form-label fw-bold" >Số lượng</label>
                    <input asp-for="Quantity" class="form-control rounded-3" min="1" max="100" />
                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label>Ảnh hiện tại:</label><br />
                    <img src="~/ImageHotel/@Model.Image" width="150" style="object-fit: cover; border-radius: 5px;" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Chọn ảnh mới (nếu muốn thay):</label>
                    <input type="file" name="imageFile" class="form-control" />
                </div>

                <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                <a asp-action="Index" class="btn btn-secondary">Hủy</a>

                <div class="mb-4">
                    <label asp-for="TourId" class="form-label fw-bold">Tour liên kết</label>
                    <select asp-for="TourId" class="form-select rounded-3" asp-items="ViewBag.Tours">
                        <option value="">-- Chọn tour --</option>
                    </select>
                    <span asp-validation-for="TourId" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-success w-100 rounded-pill">
                    ✅ Sửa khách sạn
                </button>
            </form>
        </div>
    </div>
</div>
