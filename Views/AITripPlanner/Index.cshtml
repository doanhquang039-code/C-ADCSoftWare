@model WEBDULICH.Services.AI.TripPlanRequest
@using WEBDULICH.Services.AI
@{
    ViewData["Title"] = "AI Trip Planner";
    var plan = ViewBag.Plan as TripPlanResponse;
}

@section Styles {
    <style>
        .ai-planner-shell {
            display: grid;
            grid-template-columns: minmax(280px, 380px) 1fr;
            gap: 24px;
            align-items: start;
        }

        .ai-panel, .ai-result, .ai-item {
            border: 1px solid #dee2e6;
            border-radius: 8px;
            background: #fff;
        }

        .ai-panel, .ai-result {
            padding: 20px;
        }

        .ai-title {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .ai-subtitle {
            color: #5f6b7a;
            margin-bottom: 20px;
        }

        .ai-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }

        .ai-item {
            padding: 14px;
            min-height: 110px;
        }

        .ai-item-title {
            font-weight: 700;
            margin-bottom: 6px;
        }

        .ai-meta {
            color: #5f6b7a;
            font-size: 14px;
        }

        .ai-day {
            border-left: 4px solid #0d6efd;
            padding: 10px 0 10px 14px;
            margin-bottom: 12px;
            background: #f8fbff;
        }

        .ai-empty {
            min-height: 360px;
            display: grid;
            place-items: center;
            text-align: center;
            color: #5f6b7a;
            border: 1px dashed #adb5bd;
            border-radius: 8px;
            padding: 24px;
        }

        @@media (max-width: 992px) {
            .ai-planner-shell {
                grid-template-columns: 1fr;
            }

            .ai-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="mb-4">
    <div class="ai-title">AI Trip Planner</div>
    <div class="ai-subtitle">Tao lich trinh du lich tu dong dua tren diem den, ngan sach, so ngay va du lieu tour/khach san hien co.</div>
</div>

<div class="ai-planner-shell">
    <form asp-action="Index" method="post" class="ai-panel">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label asp-for="Destination" class="form-label">Diem den</label>
            <input asp-for="Destination" class="form-control" placeholder="Vi du: Ha Long, Da Nang, Phu Quoc" />
        </div>
        <div class="row g-3">
            <div class="col-6">
                <label asp-for="Days" class="form-label">So ngay</label>
                <input asp-for="Days" class="form-control" type="number" min="1" max="14" />
            </div>
            <div class="col-6">
                <label asp-for="StartDate" class="form-label">Ngay di</label>
                <input asp-for="StartDate" class="form-control" type="date" />
            </div>
            <div class="col-6">
                <label asp-for="Adults" class="form-label">Nguoi lon</label>
                <input asp-for="Adults" class="form-control" type="number" min="1" max="30" />
            </div>
            <div class="col-6">
                <label asp-for="Children" class="form-label">Tre em</label>
                <input asp-for="Children" class="form-control" type="number" min="0" max="30" />
            </div>
        </div>
        <div class="mt-3">
            <label asp-for="Budget" class="form-label">Ngan sach du kien (VND)</label>
            <input asp-for="Budget" class="form-control" type="number" min="0" step="100000" placeholder="10000000" />
        </div>
        <div class="mt-3">
            <label asp-for="TravelStyle" class="form-label">Phong cach</label>
            <select asp-for="TravelStyle" class="form-select">
                <option value="balanced">Can bang</option>
                <option value="saving">Tiet kiem</option>
                <option value="premium">Cao cap</option>
                <option value="adventure">Kham pha</option>
            </select>
        </div>
        <div class="mt-3">
            <label asp-for="Interests" class="form-label">So thich</label>
            <input asp-for="Interests" class="form-control" placeholder="bien, am thuc, trekking, nghi duong" />
        </div>
        <button type="submit" class="btn btn-primary w-100 mt-4">
            <i class="bi bi-stars"></i> Tao lich trinh AI
        </button>
    </form>

    <section class="ai-result">
        @if (plan == null)
        {
            <div class="ai-empty">
                <div>
                    <div class="h5">Nhap thong tin chuyen di de AI lap lich trinh</div>
                    <div>Ket qua se gom lich tung ngay, tour nen chon, khach san phu hop va uoc tinh chi phi.</div>
                </div>
            </div>
        }
        else
        {
            <div class="d-flex flex-wrap justify-content-between gap-3 mb-3">
                <div>
                    <h2 class="h4 mb-1">Lich trinh goi y</h2>
                    <div class="ai-meta">@plan.Summary</div>
                </div>
                <div class="text-end">
                    <div class="fw-bold">@plan.EstimatedBudget.ToString("N0") VND</div>
                    <div class="ai-meta">@plan.BudgetStatus</div>
                </div>
            </div>

            <h3 class="h5 mt-4">Theo tung ngay</h3>
            @foreach (var day in plan.Days)
            {
                <div class="ai-day">
                    <div class="fw-bold">@day.Title</div>
                    @if (day.Date.HasValue)
                    {
                        <div class="ai-meta">@day.Date.Value.ToString("dd/MM/yyyy")</div>
                    }
                    <ul class="mb-0 mt-2">
                        @foreach (var activity in day.Activities)
                        {
                            <li>@activity</li>
                        }
                    </ul>
                </div>
            }

            <h3 class="h5 mt-4">Tour nen chon</h3>
            <div class="ai-grid">
                @foreach (var tour in plan.RecommendedTours)
                {
                    <div class="ai-item">
                        <div class="ai-item-title">@tour.Name</div>
                        <div class="ai-meta">@tour.Destination | @tour.Duration ngay | @tour.Price.ToString("N0") VND</div>
                        <div class="mt-2">@tour.Reason</div>
                        <a class="btn btn-sm btn-outline-primary mt-3" asp-controller="Tour" asp-action="Details" asp-route-id="@tour.Id">Xem tour</a>
                    </div>
                }
            </div>

            <h3 class="h5 mt-4">Khach san phu hop</h3>
            <div class="ai-grid">
                @foreach (var hotel in plan.RecommendedHotels)
                {
                    <div class="ai-item">
                        <div class="ai-item-title">@hotel.Name</div>
                        <div class="ai-meta">@hotel.Address | @hotel.PricePerNight.ToString("N0") VND/dem</div>
                        <div class="mt-2">@hotel.Reason</div>
                    </div>
                }
            </div>

            <h3 class="h5 mt-4">Luu y</h3>
            <ul>
                @foreach (var tip in plan.Tips)
                {
                    <li>@tip</li>
                }
            </ul>
        }
    </section>
</div>
