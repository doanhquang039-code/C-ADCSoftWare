@model WEBDULICH.Services.DashboardStats
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-speedometer2"></i> Admin Dashboard</h2>
        <a asp-action="Users" class="btn btn-outline-primary">
            <i class="bi bi-people"></i> Quản lý người dùng
        </a>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title opacity-75">Người dùng</h6>
                            <h2 class="mb-0">@Model.TotalUsers</h2>
                        </div>
                        <div class="fs-1 opacity-50"><i class="bi bi-people-fill"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-success text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title opacity-75">Tour</h6>
                            <h2 class="mb-0">@Model.TotalTours</h2>
                        </div>
                        <div class="fs-1 opacity-50"><i class="bi bi-compass"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-info text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title opacity-75">Khách sạn</h6>
                            <h2 class="mb-0">@Model.TotalHotels</h2>
                        </div>
                        <div class="fs-1 opacity-50"><i class="bi bi-building"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-warning text-white shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title opacity-75">Điểm đến</h6>
                            <h2 class="mb-0">@Model.TotalDestinations</h2>
                        </div>
                        <div class="fs-1 opacity-50"><i class="bi bi-geo-alt-fill"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body">
                    <h6 class="text-muted">Tổng đơn hàng</h6>
                    <h3 class="text-primary">@Model.TotalOrders</h3>
                    <small class="text-success">
                        <i class="bi bi-check-circle"></i> @Model.PaidOrders đã thanh toán
                    </small>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body">
                    <h6 class="text-muted">Doanh thu</h6>
                    <h3 class="text-success">@Model.TotalRevenue.ToString("N0") VND</h3>
                    <small class="text-muted">Từ đơn đã thanh toán</small>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body">
                    <h6 class="text-muted">Đánh giá</h6>
                    <h3 class="text-info">@Model.TotalReviews</h3>
                    <small class="text-muted">Tổng số review</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4 g-3">
        <div class="col-md-4">
            <a asp-controller="Tour" asp-action="Index" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-compass fs-1 text-success"></i>
                        <h6 class="mt-2">Quản lý Tour</h6>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Hotel" asp-action="Index" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-building fs-1 text-info"></i>
                        <h6 class="mt-2">Quản lý Khách sạn</h6>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Category" asp-action="Index" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-tags fs-1 text-warning"></i>
                        <h6 class="mt-2">Quản lý Danh mục</h6>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Destination" asp-action="Index" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-geo-alt fs-1 text-danger"></i>
                        <h6 class="mt-2">Quản lý Điểm đến</h6>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Orders" asp-action="PaidOrders" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-cart-check fs-1 text-primary"></i>
                        <h6 class="mt-2">Đơn đã thanh toán</h6>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Payment" asp-action="Index" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-credit-card fs-1 text-secondary"></i>
                        <h6 class="mt-2">Quản lý Thanh toán</h6>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- Advanced Features Row -->
    <div class="row mt-4 g-3">
        <div class="col-12">
            <h5 class="text-muted mb-3"><i class="bi bi-stars"></i> Advanced Features</h5>
        </div>
        
        <div class="col-md-3">
            <a asp-controller="Report" asp-action="Index" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100 border-primary">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-graph-up fs-1 text-primary"></i>
                        <h6 class="mt-2">Reports & Analytics</h6>
                        <small class="text-muted">Revenue & booking reports</small>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col-md-3">
            <a asp-controller="Map" asp-action="Index" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100 border-success">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-map fs-1 text-success"></i>
                        <h6 class="mt-2">Interactive Map</h6>
                        <small class="text-muted">Location management</small>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col-md-3">
            <a asp-controller="EmailMarketing" asp-action="Index" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100 border-warning">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-envelope fs-1 text-warning"></i>
                        <h6 class="mt-2">Email Marketing</h6>
                        <small class="text-muted">Campaigns & newsletters</small>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col-md-3">
            <a asp-controller="Loyalty" asp-action="Index" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100 border-info">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-award fs-1 text-info"></i>
                        <h6 class="mt-2">Loyalty Program</h6>
                        <small class="text-muted">Points & rewards</small>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- Analytics & Insights Row -->
    <div class="row mt-4 g-3">
        <div class="col-12">
            <h5 class="text-muted mb-3"><i class="bi bi-graph-up-arrow"></i> Analytics & Insights</h5>
        </div>
        
        <div class="col-md-6">
            <a asp-controller="Analytics" asp-action="Index" class="text-decoration-none">
                <div class="card shadow border-0 h-100 bg-gradient-primary text-white">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-graph-up-arrow fs-1 mb-2"></i>
                        <h5 class="mt-2">Advanced Analytics</h5>
                        <small>Comprehensive business insights</small>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col-md-6">
            <a asp-controller="Report" asp-action="Generate" class="text-decoration-none">
                <div class="card shadow border-0 h-100 bg-gradient-success text-white">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-file-earmark-bar-graph fs-1 mb-2"></i>
                        <h5 class="mt-2">Quick Reports</h5>
                        <small>Generate instant reports</small>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .bg-gradient-primary { 
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); 
        }
        .bg-gradient-success { 
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); 
        }
    </style>
}
