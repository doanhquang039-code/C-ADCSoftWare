@model WEBDULICH.Models.PagedResult<WEBDULICH.Models.Review>
@{
    ViewData["Title"] = "Danh sách đánh giá";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>⭐ Danh sách đánh giá</h2>
        <a asp-action="Create" class="btn btn-success">➕ Viết đánh giá</a>
    </div>

    <!-- Search & Filter -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <input type="text" name="keyword" class="form-control" placeholder="Tìm theo nội dung, tên user..."
                           value="@Model.Keyword" />
                </div>
                <div class="col-md-2">
                    <select name="tourId" class="form-select">
                        <option value="">-- Tour --</option>
                        @if (ViewBag.Tours != null)
                        {
                            foreach (var t in (List<WEBDULICH.Models.Tour>)ViewBag.Tours)
                            {
                                <option value="@t.Id"
                                        selected="@(Model.Filters.GetValueOrDefault("tourId") == t.Id.ToString())">
                                    @t.Name
                                </option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="rating" class="form-select">
                        <option value="">-- Số sao --</option>
                        @for (int r = 1; r <= 5; r++)
                        {
                            <option value="@r" selected="@(Model.Filters.GetValueOrDefault("rating") == r.ToString())">
                                @r ⭐
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="sortBy" class="form-select">
                        <option value="">-- Sắp xếp --</option>
                        <option value="date" selected="@(Model.SortBy == "date")">Ngày</option>
                        <option value="rating" selected="@(Model.SortBy == "rating")">Đánh giá</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <select name="sortDir" class="form-select">
                        <option value="desc" selected="@(Model.SortDir == "desc")">↓</option>
                        <option value="asc" selected="@(Model.SortDir == "asc")">↑</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">🔍</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <p class="text-muted">Tìm thấy <strong>@Model.TotalCount</strong> đánh giá</p>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-primary text-center">
                    <tr>
                        <th>Người dùng</th>
                        <th>Tour</th>
                        <th>Đánh giá</th>
                        <th>Nội dung</th>
                        <th>Ngày</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.User?.Name</td>
                            <td>@(item.Tour?.Name ?? "Không có tour")</td>
                            <td class="text-center">
                                @item.Rating ⭐
                                @{
                                    int ratingVal = 0;
                                    int.TryParse(item.Rating, out ratingVal);
                                }
                                @if (ratingVal >= 3)
                                {
                                    <span class="badge bg-success">👍 Hài lòng</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">😐 Bình thường</span>
                                }
                            </td>
                            <td>@item.Comment</td>
                            <td>@item.ReviewDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">✏️</a>
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id"
                                   onclick="return confirm('Xóa review này?')">🗑️</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index"
                       asp-route-keyword="@Model.Keyword" asp-route-tourId="@Model.Filters.GetValueOrDefault("tourId")"
                       asp-route-rating="@Model.Filters.GetValueOrDefault("rating")"
                       asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir"
                       asp-route-page="@(Model.Page - 1)"><i class="bi bi-chevron-left"></i></a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-keyword="@Model.Keyword" asp-route-tourId="@Model.Filters.GetValueOrDefault("tourId")"
                           asp-route-rating="@Model.Filters.GetValueOrDefault("rating")"
                           asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir"
                           asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index"
                       asp-route-keyword="@Model.Keyword" asp-route-tourId="@Model.Filters.GetValueOrDefault("tourId")"
                       asp-route-rating="@Model.Filters.GetValueOrDefault("rating")"
                       asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir"
                       asp-route-page="@(Model.Page + 1)"><i class="bi bi-chevron-right"></i></a>
                </li>
            </ul>
        </nav>
    }
</div>
