@model WEBDULICH.Models.PagedResult<WEBDULICH.Models.Payment>
@{
    ViewData["Title"] = "Quản lý thanh toán";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>💳 Quản lý thanh toán</h2>
        <a asp-action="Create" class="btn btn-success">➕ Thêm thanh toán</a>
    </div>

    <!-- Search & Filter -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <input type="text" name="keyword" class="form-control" placeholder="Tìm theo phương thức, trạng thái..."
                           value="@Model.Keyword" />
                </div>
                <div class="col-md-2">
                    <select name="paymentStatus" class="form-select">
                        <option value="">-- Trạng thái --</option>
                        <option value="Pending" selected="@(Model.Filters.GetValueOrDefault("paymentStatus") == "Pending")">Pending</option>
                        <option value="Completed" selected="@(Model.Filters.GetValueOrDefault("paymentStatus") == "Completed")">Completed</option>
                        <option value="Failed" selected="@(Model.Filters.GetValueOrDefault("paymentStatus") == "Failed")">Failed</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="sortBy" class="form-select">
                        <option value="">-- Sắp xếp --</option>
                        <option value="date" selected="@(Model.SortBy == "date")">Ngày</option>
                        <option value="amount" selected="@(Model.SortBy == "amount")">Số tiền</option>
                        <option value="method" selected="@(Model.SortBy == "method")">Phương thức</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="sortDir" class="form-select">
                        <option value="desc" selected="@(Model.SortDir == "desc")">Giảm dần</option>
                        <option value="asc" selected="@(Model.SortDir == "asc")">Tăng dần</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">🔍 Tìm</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <p class="text-muted">Tìm thấy <strong>@Model.TotalCount</strong> giao dịch</p>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Đơn hàng #</th>
                            <th>Phương thức</th>
                            <th>Trạng thái</th>
                            <th>Số tiền</th>
                            <th>Ngày thanh toán</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Items)
                        {
                            <tr>
                                <td>@p.Id</td>
                                <td>
                                    <a asp-controller="Orders" asp-action="Transfer" asp-route-id="@p.OrdersId"
                                       class="text-primary fw-bold">#@p.OrdersId</a>
                                </td>
                                <td>
                                    @if (p.PaymentMethod == "Chuyển khoản")
                                    {
                                        <span class="badge bg-info">🏦 @p.PaymentMethod</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">💵 @p.PaymentMethod</span>
                                    }
                                </td>
                                <td>
                                    @if (p.PaymentStatus == "Completed")
                                    {
                                        <span class="badge bg-success">✅ Hoàn thành</span>
                                    }
                                    else if (p.PaymentStatus == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark">⏳ Đang xử lý</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">❌ Thất bại</span>
                                    }
                                </td>
                                <td class="fw-bold text-success">@p.Amount.ToString("N0") $</td>
                                <td>@p.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-outline-primary">✏️</a>
                                        <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-outline-danger"
                                           onclick="return confirm('Xóa giao dịch này?')">🗑️</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index"
                       asp-route-keyword="@Model.Keyword" asp-route-paymentStatus="@Model.Filters.GetValueOrDefault("paymentStatus")"
                       asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir"
                       asp-route-page="@(Model.Page - 1)"><i class="bi bi-chevron-left"></i></a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-keyword="@Model.Keyword" asp-route-paymentStatus="@Model.Filters.GetValueOrDefault("paymentStatus")"
                           asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir"
                           asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index"
                       asp-route-keyword="@Model.Keyword" asp-route-paymentStatus="@Model.Filters.GetValueOrDefault("paymentStatus")"
                       asp-route-sortBy="@Model.SortBy" asp-route-sortDir="@Model.SortDir"
                       asp-route-page="@(Model.Page + 1)"><i class="bi bi-chevron-right"></i></a>
                </li>
            </ul>
        </nav>
    }
</div>
