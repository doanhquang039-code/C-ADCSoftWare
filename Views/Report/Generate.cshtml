@{
    ViewData["Title"] = "Generate Report";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-graph-up-arrow"></i> Generate New Report</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Reports
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Revenue Report -->
        <div class="col-md-6">
            <div class="card shadow h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-currency-dollar"></i> Revenue Report</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Generate detailed revenue analysis including daily trends, top tours, and hotels performance.</p>
                    
                    <form asp-action="GenerateRevenue" method="post">
                        <div class="mb-3">
                            <label class="form-label">Report Title</label>
                            <input type="text" name="title" class="form-control" 
                                   value="Revenue Report - @DateTime.Now.ToString("MMMM yyyy")" required>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">From Date</label>
                                    <input type="date" name="fromDate" class="form-control" 
                                           value="@DateTime.Now.AddDays(-30).ToString("yyyy-MM-dd")" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">To Date</label>
                                    <input type="date" name="toDate" class="form-control" 
                                           value="@DateTime.Now.ToString("yyyy-MM-dd")" required>
                                </div>
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-play-circle"></i> Generate Revenue Report
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Booking Report -->
        <div class="col-md-6">
            <div class="card shadow h-100">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-calendar-check"></i> Booking Report</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Analyze booking patterns, cancellation rates, and popular destinations.</p>
                    
                    <form asp-action="GenerateBooking" method="post">
                        <div class="mb-3">
                            <label class="form-label">Report Title</label>
                            <input type="text" name="title" class="form-control" 
                                   value="Booking Report - @DateTime.Now.ToString("MMMM yyyy")" required>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">From Date</label>
                                    <input type="date" name="fromDate" class="form-control" 
                                           value="@DateTime.Now.AddDays(-30).ToString("yyyy-MM-dd")" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">To Date</label>
                                    <input type="date" name="toDate" class="form-control" 
                                           value="@DateTime.Now.ToString("yyyy-MM-dd")" required>
                                </div>
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-success w-100">
                            <i class="bi bi-play-circle"></i> Generate Booking Report
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-lightning"></i> Quick Reports</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <form asp-action="GenerateRevenue" method="post">
                                <input type="hidden" name="title" value="Last 7 Days Revenue">
                                <input type="hidden" name="fromDate" value="@DateTime.Now.AddDays(-7).ToString("yyyy-MM-dd")">
                                <input type="hidden" name="toDate" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                                <button type="submit" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-calendar-week"></i><br>Last 7 Days<br>Revenue
                                </button>
                            </form>
                        </div>
                        <div class="col-md-3">
                            <form asp-action="GenerateRevenue" method="post">
                                <input type="hidden" name="title" value="This Month Revenue">
                                <input type="hidden" name="fromDate" value="@(new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1).ToString("yyyy-MM-dd"))">
                                <input type="hidden" name="toDate" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                                <button type="submit" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-calendar-month"></i><br>This Month<br>Revenue
                                </button>
                            </form>
                        </div>
                        <div class="col-md-3">
                            <form asp-action="GenerateBooking" method="post">
                                <input type="hidden" name="title" value="Last 30 Days Bookings">
                                <input type="hidden" name="fromDate" value="@DateTime.Now.AddDays(-30).ToString("yyyy-MM-dd")">
                                <input type="hidden" name="toDate" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                                <button type="submit" class="btn btn-outline-success w-100">
                                    <i class="bi bi-calendar-range"></i><br>Last 30 Days<br>Bookings
                                </button>
                            </form>
                        </div>
                        <div class="col-md-3">
                            <form asp-action="GenerateBooking" method="post">
                                <input type="hidden" name="title" value="This Year Bookings">
                                <input type="hidden" name="fromDate" value="@(new DateTime(DateTime.Now.Year, 1, 1).ToString("yyyy-MM-dd"))">
                                <input type="hidden" name="toDate" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                                <button type="submit" class="btn btn-outline-success w-100">
                                    <i class="bi bi-calendar4"></i><br>This Year<br>Bookings
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>