@model List<WEBDULICH.Models.Report>
@{
    ViewData["Title"] = "Reports Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-graph-up"></i> Reports Management</h2>
        <a asp-action="Generate" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Generate New Report
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Title</th>
                            <th>Type</th>
                            <th>Period</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var report in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@report.Title</strong>
                                        @if (!string.IsNullOrEmpty(report.Description))
                                        {
                                            <br><small class="text-muted">@report.Description</small>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@report.ReportType</span>
                                    </td>
                                    <td>
                                        <small>
                                            @report.FromDate.ToString("dd/MM/yyyy") - 
                                            @report.ToDate.ToString("dd/MM/yyyy")
                                        </small>
                                    </td>
                                    <td>
                                        @if (report.Status == "Generated")
                                        {
                                            <span class="badge bg-success">Generated</span>
                                        }
                                        else if (report.Status == "Scheduled")
                                        {
                                            <span class="badge bg-warning">Scheduled</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Failed</span>
                                        }
                                    </td>
                                    <td>
                                        <small>@report.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="View" asp-route-id="@report.Id" 
                                               class="btn btn-sm btn-outline-primary" title="View Report">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="ExportPdf" asp-route-id="@report.Id" 
                                               class="btn btn-sm btn-outline-secondary" title="Export PDF">
                                                <i class="bi bi-file-pdf"></i>
                                            </a>
                                            <a asp-action="ExportExcel" asp-route-id="@report.Id" 
                                               class="btn btn-sm btn-outline-success" title="Export Excel">
                                                <i class="bi bi-file-excel"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@report.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" 
                                                        onclick="return confirm('Are you sure you want to delete this report?')" 
                                                        title="Delete Report">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-1"></i>
                                    <br>No reports generated yet.
                                    <br><a asp-action="Generate" class="btn btn-primary mt-2">Generate Your First Report</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>