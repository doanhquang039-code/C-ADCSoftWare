@using WEBDULICH.Models
@model IEnumerable<DynamicPricingRule>

@{
    var recentChanges = ViewBag.RecentChanges as List<PriceHistory>;
    var stats = ViewBag.Stats as Dictionary<string, object>;
    ViewData["Title"] = "Price Optimization Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 class="mb-0 text-danger"><i class="fas fa-chart-line me-2"></i>Tối Ưu Hóa Giá (Dynamic Pricing)</h2>
            <button class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Thêm Quy Tắc Mới
            </button>
        </div>
    </div>

    <!-- Statistics -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white shadow h-100">
                <div class="card-body">
                    <h6 class="text-white-50">Tổng Quy Tắc</h6>
                    <h2 class="mb-0">@(stats != null && stats.ContainsKey("TotalRules") ? stats["TotalRules"] : "0")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white shadow h-100">
                <div class="card-body">
                    <h6 class="text-white-50">Đang Hoạt Động</h6>
                    <h2 class="mb-0">@(stats != null && stats.ContainsKey("ActiveRules") ? stats["ActiveRules"] : "0")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white shadow h-100">
                <div class="card-body">
                    <h6 class="text-white-50">Thay Đổi Giá (Tháng)</h6>
                    <h2 class="mb-0">@(stats != null && stats.ContainsKey("PriceChangesThisMonth") ? stats["PriceChangesThisMonth"] : "0")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark shadow h-100">
                <div class="card-body">
                    <h6 class="text-dark-50">Mức Tăng Trưởng Lợi Nhuận</h6>
                    <h2 class="mb-0">@(stats != null && stats.ContainsKey("RevenueIncrease") ? stats["RevenueIncrease"] + "%" : "15%")</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Rules List -->
        <div class="col-md-8 mb-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-primary">Các Quy Tắc Định Giá</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tên Quy Tắc</th>
                                    <th>Loại</th>
                                    <th>Đối Tượng</th>
                                    <th>Mức Điều Chỉnh</th>
                                    <th>Trạng Thái</th>
                                    <th>Hành Động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var rule in Model)
                                    {
                                        <tr>
                                            <td class="fw-bold">@rule.Name</td>
                                            <td>@rule.RuleType</td>
                                            <td>@rule.AppliesTo</td>
                                            <td class="text-danger fw-bold">@(rule.ActionValue > 0 ? "+" : "")@rule.ActionValue%</td>
                                            <td>
                                                <span class="badge @(rule.IsActive ? "bg-success" : "bg-secondary")">
                                                    @(rule.IsActive ? "Active" : "Inactive")
                                                </span>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></button>
                                                <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">Chưa có quy tắc nào</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Changes -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-success">Biến Động Gần Đây</h5>
                </div>
                <div class="card-body">
                    @if (recentChanges != null && recentChanges.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var change in recentChanges)
                            {
                                var diff = change.NewPrice - change.OldPrice;
                                var isIncrease = diff > 0;
                                
                                <div class="list-group-item px-0 py-3">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1 fw-bold">@change.EntityType #@(change.TourId ?? change.HotelId)</h6>
                                        <small class="text-muted">@change.EffectiveDate.ToString("dd/MM HH:mm")</small>
                                    </div>
                                    <p class="mb-1 text-muted small">@change.ChangeReason</p>
                                    <div class="d-flex align-items-center mt-2">
                                        <span class="text-decoration-line-through text-muted small me-2">
                                            @change.OldPrice.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))
                                        </span>
                                        <i class="fas fa-arrow-right text-muted mx-2"></i>
                                        <span class="fw-bold @(isIncrease ? "text-success" : "text-danger")">
                                            @change.NewPrice.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4">Chưa có thay đổi giá nào gần đây.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
