@model Dictionary<string, object>

@{
    ViewData["Title"] = "Review Analytics Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 class="mb-0 text-success"><i class="fas fa-star-half-alt me-2"></i>Phân Tích Đánh Giá (Review Analytics)</h2>
            <button class="btn btn-primary" onclick="alert('Tính năng đang được cập nhật!')">
                <i class="fas fa-robot me-2"></i>Chạy AI Quét Spam
            </button>
        </div>
    </div>

    <!-- Key Metrics -->
    <div class="row mb-4">
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card border-0 shadow-sm h-100 bg-white border-start border-4 border-primary">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Tổng Số Đánh Giá</h6>
                    <h2 class="fw-bold mb-0 text-primary">
                        @(Model != null && Model.ContainsKey("TotalReviews") ? Model["TotalReviews"] : "0")
                    </h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card border-0 shadow-sm h-100 bg-white border-start border-4 border-success">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Điểm Đánh Giá TB</h6>
                    <h2 class="fw-bold mb-0 text-success">
                        @(Model != null && Model.ContainsKey("AverageRating") ? Model["AverageRating"] : "0.0") <i class="fas fa-star fs-5 text-warning"></i>
                    </h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card border-0 shadow-sm h-100 bg-white border-start border-4 border-info">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Tỷ Lệ Tích Cực (Positive)</h6>
                    <h2 class="fw-bold mb-0 text-info">
                        @(Model != null && Model.ContainsKey("PositivePercentage") ? Model["PositivePercentage"] + "%" : "0%")
                    </h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card border-0 shadow-sm h-100 bg-white border-start border-4 border-danger">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Đánh Giá Spam/Fake</h6>
                    <h2 class="fw-bold mb-0 text-danger">
                        @(Model != null && Model.ContainsKey("SpamCount") ? Model["SpamCount"] : "0")
                    </h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Sentiment Analysis -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-dark">Phân Tích Cảm Xúc (Sentiment Analysis)</h5>
                </div>
                <div class="card-body d-flex justify-content-center align-items-center">
                    <div class="text-center w-100">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-success fw-bold"><i class="fas fa-smile me-1"></i>Tích cực</span>
                            <span class="text-success">75%</span>
                        </div>
                        <div class="progress mb-4" style="height: 10px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: 75%"></div>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-secondary fw-bold"><i class="fas fa-meh me-1"></i>Trung lập</span>
                            <span class="text-secondary">15%</span>
                        </div>
                        <div class="progress mb-4" style="height: 10px;">
                            <div class="progress-bar bg-secondary" role="progressbar" style="width: 15%"></div>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-danger fw-bold"><i class="fas fa-frown me-1"></i>Tiêu cực</span>
                            <span class="text-danger">10%</span>
                        </div>
                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar bg-danger" role="progressbar" style="width: 10%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Top Keywords -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-dark">Từ Khóa Phổ Biến Nhất (Top Keywords)</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge rounded-pill bg-light text-dark border p-2">sạch sẽ (124)</span>
                        <span class="badge rounded-pill bg-light text-dark border p-2">thân thiện (98)</span>
                        <span class="badge rounded-pill bg-light text-dark border p-2">hơi ồn (45)</span>
                        <span class="badge rounded-pill bg-light text-dark border p-2">view đẹp (210)</span>
                        <span class="badge rounded-pill bg-light text-dark border p-2">giá hợp lý (150)</span>
                        <span class="badge rounded-pill bg-light text-dark border p-2">xa trung tâm (30)</span>
                        <span class="badge rounded-pill bg-light text-dark border p-2">đồ ăn ngon (180)</span>
                        <span class="badge rounded-pill bg-light text-dark border p-2">Wifi yếu (25)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
