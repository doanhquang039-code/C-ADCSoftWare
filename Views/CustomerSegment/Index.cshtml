@using WEBDULICH.Models
@model IEnumerable<CustomerSegment>

@{
    ViewData["Title"] = "Customer Segments";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 class="mb-0">Phân Khúc Khách Hàng (Customer Segments)</h2>
            <button class="btn btn-primary" onclick="analyzeSegments()">
                <i class="fas fa-magic me-2"></i>Tự Động Phân Tích & Phân Khúc (AI)
            </button>
        </div>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var segment in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body">
                            <h5 class="card-title fw-bold text-primary">@segment.Name</h5>
                            <p class="card-text text-muted">@segment.Description</p>
                            
                            <div class="d-flex justify-content-between mt-4">
                                <div>
                                    <small class="text-muted d-block">LTV Trung bình</small>
                                    <span class="fw-bold">@segment.LifetimeValue.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</span>
                                </div>
                            </div>

                            <hr />

                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge bg-info text-dark">
                                    Churn Rate: @segment.ChurnRate%
                                </span>
                                <a href="/admin/customer-segments/@segment.Id/insights" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-chart-line me-1"></i> Xem Phân Tích
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <img src="~/images/empty-state.png" alt="No data" class="img-fluid mb-3" style="max-width: 200px; opacity: 0.5" />
                <h4 class="text-muted">Chưa có phân khúc khách hàng nào</h4>
                <p class="text-muted">Nhấn nút "Tự Động Phân Tích" để hệ thống dùng AI phân khúc tập khách hàng của bạn.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function analyzeSegments() {
            if (confirm("Hệ thống sẽ tiến hành phân tích lại toàn bộ dữ liệu người dùng. Bạn có chắc chắn muốn tiếp tục?")) {
                // Show loading spinner
                document.body.style.cursor = 'wait';
                
                fetch('/api/CustomerSegment/analyze', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert("Phân tích thành công! Đã tạo " + data.count + " phân khúc.");
                        window.location.reload();
                    } else {
                        alert("Lỗi: " + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert("Đã xảy ra lỗi khi phân tích dữ liệu.");
                })
                .finally(() => {
                    document.body.style.cursor = 'default';
                });
            }
        }
    </script>
}
