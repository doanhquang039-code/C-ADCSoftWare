@model WEBDULICH.Services.DashboardStats
@{
    ViewData["Title"] = "Manager Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 class="mb-0 text-primary"><i class="bi bi-briefcase me-2"></i>Khu vực Quản lý (Manager)</h2>
            <div>
                <span class="text-muted me-3">Hôm nay: @DateTime.Now.ToString("dd/MM/yyyy")</span>
            </div>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row mb-4">
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card border-0 shadow-sm h-100 bg-white border-start border-4 border-primary">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Đơn Hàng Mới</h6>
                    <h2 class="fw-bold mb-0 text-primary">@Model.TotalOrders</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card border-0 shadow-sm h-100 bg-white border-start border-4 border-success">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Đơn Đã Thanh Toán</h6>
                    <h2 class="fw-bold mb-0 text-success">@Model.PaidOrders</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card border-0 shadow-sm h-100 bg-white border-start border-4 border-info">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Tổng Số Tour</h6>
                    <h2 class="fw-bold mb-0 text-info">@Model.TotalTours</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card border-0 shadow-sm h-100 bg-white border-start border-4 border-warning">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Đánh Giá (Reviews)</h6>
                    <h2 class="fw-bold mb-0 text-warning">@Model.TotalReviews</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Quick Actions -->
        <div class="col-md-12 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Công cụ Vận Hành</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center g-3">
                        <div class="col-md-3 col-sm-6">
                            <a href="/Orders" class="text-decoration-none">
                                <div class="p-4 border rounded hover-shadow transition-all text-dark bg-light h-100">
                                    <i class="bi bi-cart-check fs-1 text-primary mb-2 d-block"></i>
                                    <h6 class="fw-bold">Quản lý Đơn hàng</h6>
                                </div>
                            </a>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <a href="/Tour" class="text-decoration-none">
                                <div class="p-4 border rounded hover-shadow transition-all text-dark bg-light h-100">
                                    <i class="bi bi-geo-alt fs-1 text-success mb-2 d-block"></i>
                                    <h6 class="fw-bold">Quản lý Tour</h6>
                                </div>
                            </a>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <a href="/Hotel" class="text-decoration-none">
                                <div class="p-4 border rounded hover-shadow transition-all text-dark bg-light h-100">
                                    <i class="bi bi-building fs-1 text-info mb-2 d-block"></i>
                                    <h6 class="fw-bold">Quản lý Khách sạn</h6>
                                </div>
                            </a>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <a href="/Review" class="text-decoration-none">
                                <div class="p-4 border rounded hover-shadow transition-all text-dark bg-light h-100">
                                    <i class="bi bi-star fs-1 text-warning mb-2 d-block"></i>
                                    <h6 class="fw-bold">Duyệt Đánh giá</h6>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-shadow:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        transform: translateY(-2px);
    }
    .transition-all {
        transition: all 0.2s ease-in-out;
    }
</style>
